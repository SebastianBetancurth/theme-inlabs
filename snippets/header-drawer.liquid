<style>
  @media screen and (max-width: 989px) {
    .js .menu-drawer,
    .menu-drawer {
      position: fixed;
      top: auto;
      bottom: 1rem;
      left: 1rem;
      right: 1rem;
      width: auto;
      height: 76dvh;
      max-height: 72rem;
      background: transparent;
      border-radius: 1.6rem;
      overflow: visible;
      transform: translateY(120%);
      visibility: hidden;
      z-index: 30;
      filter: none;
    }

    .js details[open] > .menu-drawer {
      transition: transform 0.5s cubic-bezier(0.32, 0.72, 0, 1), visibility 0.5s cubic-bezier(0.32, 0.72, 0, 1);
    }

    .js details[open].menu-opening > .menu-drawer {
      transform: translateY(0);
      visibility: visible;
    }

    .js header-drawer > details > summary::before,
    .js header-drawer > details[open]:not(.menu-opening) > summary::before {
      content: '';
      position: fixed !important;
      top: 0 !important;
      left: 0 !important;
      width: 100% !important;
      height: 100vh !important;
      height: 100dvh !important;
      background: rgba(0, 0, 0, 0.65) !important;
      opacity: 0;
      visibility: hidden;
      z-index: 20;
      cursor: default;
      transition: opacity 0.4s ease, visibility 0.4s ease !important;
    }

    .js header-drawer > details[open].menu-opening > summary::before {
      opacity: 1 !important;
      visibility: visible !important;
    }

    .section-header {
      z-index: 4;
    }

    .shopify-section.section-scrolling-banner {
      position: relative;
      z-index: 1;
    }

    .menu-drawer__inner-container {
      background: #ffffff;
      border-radius: 1.6rem;
      overflow: hidden;
      height: 100%;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    }

    .menu-drawer__floating-close {
      position: absolute;
      top: -6.6rem;
      left: 50%;
      transform: translateX(-50%);
      width: 4.8rem;
      height: 4.8rem;
      border-radius: 50%;
      background: #ffffff;
      border: none;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      padding: 0;
      z-index: 31;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
    }

    .menu-drawer__floating-close svg {
      width: 1.5rem;
      height: 1.5rem;
      color: #111111;
    }

    .menu-drawer__navigation {
      padding: 1rem 0 2rem;
    }

    .js .menu-drawer__menu > li {
      margin: 0 2.4rem;
      border-bottom: 0.1rem solid rgba(0, 0, 0, 0.4);
    }

    .menu-drawer summary.menu-drawer__menu-item {
      position: relative;
      padding-right: 4.6rem;
    }

    .menu-drawer__menu-item,
    .menu-drawer__menu-item--active,
    .menu-drawer__menu-item:focus,
    .menu-drawer__menu-item:hover,
    .menu-drawer__menu-item--active:hover {
      padding: 2rem 0;
      font-size: 1.6rem;
      color: #111111;
      background-color: transparent;
      text-decoration: none !important;
    }

    .menu-drawer summary.menu-drawer__menu-item > .svg-wrapper:nth-of-type(1) {
      display: none;
    }

    .js .menu-drawer .menu-drawer__menu-item .icon-caret {
      display: block;
      position: static;
      width: 1.1rem;
      height: 1.1rem;
      transition: transform 0.3s ease;
    }

    .menu-drawer summary.menu-drawer__menu-item > .svg-wrapper:nth-of-type(2) {
      width: 3rem;
      height: 3rem;
      right: 0;
      background: #f0f0f0;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .menu-drawer__accordion[open] > summary .icon-caret {
      transform: rotate(180deg);
    }

    .menu-drawer__accordion-list {
      list-style: none;
      margin: 0;
      padding: 0 0 1.4rem;
    }

    .menu-drawer__accordion[open] > .menu-drawer__accordion-list {
      animation: drawer-accordion-reveal 0.35s ease;
    }

    @keyframes drawer-accordion-reveal {
      from {
        opacity: 0;
        transform: translateY(-0.6rem);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .menu-drawer__product {
      display: flex;
      align-items: center;
      gap: 1.2rem;
      padding: 0.9rem 0;
      color: #111111;
      text-decoration: none !important;
    }

    .menu-drawer__product-image {
      width: 4rem;
      height: 4rem;
      object-fit: contain;
      flex-shrink: 0;
    }

    .menu-drawer__product-title {
      display: block;
      font-size: 1.4rem;
      line-height: 1.2;
      color: #111111;
    }

    .menu-drawer__product-tagline {
      display: block;
      font-size: 1.1rem;
      margin-top: 0.2rem;
      color: rgba(0, 0, 0, 0.55);
    }

    .menu-drawer__accordion-link {
      display: block;
      padding: 0.9rem 0;
      font-size: 1.4rem;
      color: #111111;
      text-decoration: none !important;
    }

    .menu-drawer__utility-links {
      background-color: transparent;
      padding: 1.6rem 2.4rem 2rem !important;
    }

    .menu-drawer .list-social {
      margin-left: -1.1rem;
    }

    .menu-drawer .list-social__link {
      color: #111111;
    }

    .menu-drawer__bottom-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-top: 0.1rem solid rgba(0, 0, 0, 0.15);
      padding-top: 1.6rem;
      margin-top: 1.2rem;
    }

    .menu-drawer__localization {
      display: flex;
      align-items: center;
      gap: 0.8rem;
    }

    .menu-drawer__localization .disclosure__button {
      padding: 0;
      font-size: 1.4rem;
      color: #111111;
      text-decoration: none !important;
    }

    .menu-drawer__localization .disclosure__button > svg,
    .menu-drawer__localization .disclosure__button .icon-caret {
      display: none;
    }

    .menu-drawer__loc-divider {
      color: #111111;
      font-size: 1.4rem;
    }

    .menu-drawer__account,
    .menu-drawer__account:hover {
      padding: 0;
      font-size: 1.4rem;
      color: #111111;
      text-decoration: none !important;
    }

    .menu-drawer__account .svg-wrapper,
    .menu-drawer__account account-icon {
      display: none;
    }

    .menu-drawer__utility-links:has(.menu-drawer__localization) .menu-drawer__account {
      margin: 0;
    }
  }
</style>

{%- liquid
  assign drawer_menu = section.settings.menu
  if section.settings.mobile_menu != blank
    assign drawer_menu = section.settings.mobile_menu
  endif
-%}

<header-drawer data-breakpoint="{% if section.settings.menu_type_desktop == 'drawer' %}desktop{% else %}tablet{% endif %}">
  <details id="Details-menu-drawer-container" class="menu-drawer-container">
    <summary
      class="header__icon header__icon--menu header__icon--summary link focus-inset"
      aria-label="{{ 'sections.header.menu' | t }}"
    >
      <span>
        {{- 'icon-hamburger.svg' | inline_asset_content -}}
        {{- 'icon-close.svg' | inline_asset_content -}}
      </span>
    </summary>
    <div id="menu-drawer" class="gradient menu-drawer motion-reduce color-{{ section.settings.menu_color_scheme }}">
      <button
        type="button"
        class="menu-drawer__floating-close"
        aria-label="{{ 'accessibility.close' | t }}"
        onclick="this.closest('details').querySelector('summary').click()"
      >
        {{- 'icon-close.svg' | inline_asset_content -}}
      </button>
      <div class="menu-drawer__inner-container">
        <div class="menu-drawer__navigation-container">
          <nav class="menu-drawer__navigation">
            <ul class="menu-drawer__menu list-menu" role="list">
              {%- for link in drawer_menu.links -%}
                <li>
                  {%- if link.links != blank -%}
                    <details id="Details-menu-drawer-menu-item-{{ forloop.index }}" class="menu-drawer__accordion">
                      <summary
                        id="HeaderDrawer-{{ link.handle }}"
                        class="menu-drawer__menu-item list-menu__item link link--text focus-inset{% if link.child_active %} menu-drawer__menu-item--active{% endif %}"
                      >
                        {{ link.title | escape }}
                        <span class="svg-wrapper">
                          {{- 'icon-arrow.svg' | inline_asset_content -}}
                        </span>
                        <span class="svg-wrapper">
                          {{- 'icon-caret.svg' | inline_asset_content -}}
                        </span>
                      </summary>
                      <ul class="menu-drawer__accordion-list" role="list">
                        {%- for childlink in link.links -%}
                          <li>
                            {%- if childlink.type == 'product_link' and childlink.object != blank -%}
                              <a
                                id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}"
                                href="{{ childlink.url }}"
                                class="menu-drawer__product focus-inset"
                                {% if childlink.current %}
                                  aria-current="page"
                                {% endif %}
                              >
                                {%- if childlink.object.featured_image != blank -%}
                                  {{
                                    childlink.object.featured_image
                                    | image_url: width: 120
                                    | image_tag:
                                      class: 'menu-drawer__product-image',
                                      widths: '80, 120',
                                      alt: childlink.object.featured_image.alt,
                                      loading: 'lazy'
                                  }}
                                {%- endif -%}
                                <span>
                                  <span class="menu-drawer__product-title">{{ childlink.title | escape }}</span>
                                  {%- if childlink.object.metafields.custom.tagline != blank -%}
                                    <span class="menu-drawer__product-tagline">
                                      {{- childlink.object.metafields.custom.tagline -}}
                                    </span>
                                  {%- endif -%}
                                </span>
                              </a>
                            {%- else -%}
                              <a
                                id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}"
                                href="{{ childlink.url }}"
                                class="menu-drawer__accordion-link focus-inset{% if childlink.current %} menu-drawer__menu-item--active{% endif %}"
                                {% if childlink.current %}
                                  aria-current="page"
                                {% endif %}
                              >
                                {{ childlink.title | escape }}
                              </a>
                              {%- if childlink.links != blank -%}
                                {%- for grandchildlink in childlink.links -%}
                                  <a
                                    id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                                    href="{{ grandchildlink.url }}"
                                    class="menu-drawer__accordion-link focus-inset"
                                    {% if grandchildlink.current %}
                                      aria-current="page"
                                    {% endif %}
                                  >
                                    {{ grandchildlink.title | escape }}
                                  </a>
                                {%- endfor -%}
                              {%- endif -%}
                            {%- endif -%}
                          </li>
                        {%- endfor -%}
                      </ul>
                    </details>
                  {%- else -%}
                    <a
                      id="HeaderDrawer-{{ link.handle }}"
                      href="{{ link.url }}"
                      class="menu-drawer__menu-item list-menu__item link link--text focus-inset{% if link.current %} menu-drawer__menu-item--active{% endif %}"
                      {% if link.current %}
                        aria-current="page"
                      {% endif %}
                    >
                      {{ link.title | escape }}
                    </a>
                  {%- endif -%}
                </li>
              {%- endfor -%}
            </ul>
          </nav>
          <div class="menu-drawer__utility-links">
            <ul class="list list-social list-unstyled" role="list">
              {%- if settings.social_twitter_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_twitter_link }}" class="list-social__link link">
                    <span class="svg-wrapper">
                      {{- 'icon-twitter.svg' | inline_asset_content -}}
                    </span>
                    <span class="visually-hidden">{{ 'general.social.links.twitter' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_facebook_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_facebook_link }}" class="list-social__link link">
                    <span class="svg-wrapper">
                      {{- 'icon-facebook.svg' | inline_asset_content -}}
                    </span>
                    <span class="visually-hidden">{{ 'general.social.links.facebook' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_pinterest_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_pinterest_link }}" class="list-social__link link">
                    <span class="svg-wrapper">
                      {{- 'icon-pinterest.svg' | inline_asset_content -}}
                    </span>
                    <span class="visually-hidden">{{ 'general.social.links.pinterest' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_instagram_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_instagram_link }}" class="list-social__link link">
                    <span class="svg-wrapper">
                      {{- 'icon-instagram.svg' | inline_asset_content -}}
                    </span>
                    <span class="visually-hidden">{{ 'general.social.links.instagram' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_tiktok_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_tiktok_link }}" class="list-social__link link">
                    <span class="svg-wrapper">
                      {{- 'icon-tiktok.svg' | inline_asset_content -}}
                    </span>
                    <span class="visually-hidden">{{ 'general.social.links.tiktok' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_tumblr_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_tumblr_link }}" class="list-social__link link">
                    <span class="svg-wrapper">
                      {{- 'icon-tumblr.svg' | inline_asset_content -}}
                    </span>
                    <span class="visually-hidden">{{ 'general.social.links.tumblr' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_snapchat_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_snapchat_link }}" class="list-social__link link">
                    <span class="svg-wrapper">
                      {{- 'icon-snapchat.svg' | inline_asset_content -}}
                    </span>
                    <span class="visually-hidden">{{ 'general.social.links.snapchat' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_youtube_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_youtube_link }}" class="list-social__link link">
                    <span class="svg-wrapper">
                      {{- 'icon-youtube.svg' | inline_asset_content -}}
                    </span>
                    <span class="visually-hidden">{{ 'general.social.links.youtube' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
              {%- if settings.social_vimeo_link != blank -%}
                <li class="list-social__item">
                  <a href="{{ settings.social_vimeo_link }}" class="list-social__link link">
                    <span class="svg-wrapper">
                      {{- 'icon-vimeo.svg' | inline_asset_content -}}
                    </span>
                    <span class="visually-hidden">{{ 'general.social.links.vimeo' | t }}</span>
                  </a>
                </li>
              {%- endif -%}
            </ul>
            <div class="menu-drawer__bottom-row">
              {%- if localization.available_countries or localization.available_languages -%}
                <div class="menu-drawer__localization header-localization">
                  {%- if localization.available_countries and localization.available_countries.size > 1 -%}
                    <localization-form>
                      {%- form 'localization', id: 'HeaderCountryMobileForm', class: 'localization-form' -%}
                        <div>
                          <h2 class="visually-hidden" id="HeaderCountryMobileLabel">
                            {{ 'localization.country_label' | t }}
                          </h2>
                          {%- render 'country-localization', localPosition: 'HeaderCountryMobile' -%}
                        </div>
                      {%- endform -%}
                    </localization-form>
                  {% endif %}

                  {%- if localization.available_countries.size > 1 and localization.available_languages.size > 1 -%}
                    <span class="menu-drawer__loc-divider">|</span>
                  {%- endif -%}

                  {%- if localization.available_languages and localization.available_languages.size > 1 -%}
                    <localization-form>
                      {%- form 'localization', id: 'HeaderLanguageMobileForm', class: 'localization-form' -%}
                        <div>
                          <h2 class="visually-hidden" id="HeaderLanguageMobileLabel">
                            {{ 'localization.language_label' | t }}
                          </h2>
                          {%- render 'language-localization', localPosition: 'HeaderLanguageMobile' -%}
                        </div>
                      {%- endform -%}
                    </localization-form>
                  {%- endif -%}
                </div>
              {%- endif -%}
              {%- if shop.customer_accounts_enabled -%}
                <a
                  href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
                  class="menu-drawer__account link focus-inset h5 medium-hide large-up-hide"
                  rel="nofollow"
                >
                  {%- liquid
                    if customer
                      echo 'customer.account_fallback' | t
                    else
                      echo 'customer.log_in' | t
                    endif
                  -%}
                </a>
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>
    </div>
  </details>
</header-drawer>
