      "min": 3,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Formato de imagen",
      "options": [
        { "value": "adapt", "label": "Adaptar (imagen completa)" },
        { "value": "1 / 1", "label": "Cuadrada" },
        { "value": "4 / 5", "label": "Vertical 4:5" },
        { "value": "3 / 4", "label": "Vertical 3:4" }
      ],
      "default": "adapt"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Ajuste de imagen (si no es Adaptar)",
      "options": [
        { "value": "cover", "label": "Rellenar (recorta)" },
        { "value": "contain", "label": "Completa (sin recortar)" }
      ],
      "default": "cover"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto del botón",
      "default": "Añadir"
    },
    {
      "type": "text",
      "id": "soon_badge_text",
      "label": "Texto etiqueta próximamente",
      "default": "Próximamente..."
    },
    {
      "type": "text",
      "id": "soon_button_text",
      "label": "Texto botón próximamente",
      "default": "Próximamente..."
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Tamaño título PC (px)",
      "min": 28,
      "max": 90,
      "step": 2,
      "default": 58
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Tamaño título móvil (px)",
      "min": 20,
      "max": 50,
      "step": 2,
      "default": 32
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#f6f5f3"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espaciado superior (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espaciado inferior (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Slider de productos"
    }
  ]
}
{% endschema %}
