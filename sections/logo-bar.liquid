{%- style -%}
  .logo-bar-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .logo-bar-{{ section.id }} .logo-bar__row {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: {{ section.settings.gap_desktop }}px;
    padding: 0 2rem;
    max-width: 120rem;
    margin: 0 auto;
  }
  .logo-bar-{{ section.id }} .logo-bar__item {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .logo-bar-{{ section.id }} .logo-bar__item img,
  .logo-bar-{{ section.id }} .logo-bar__item svg {
    height: {{ section.settings.logo_height_desktop }}px;
    width: auto;
    max-width: 100%;
    object-fit: contain;
    {%- if section.settings.force_white -%}
    filter: brightness(0) invert(1);
    {%- endif -%}
  }
  @media screen and (max-width: 749px) {
    .logo-bar-{{ section.id }} .logo-bar__row {
      gap: {{ section.settings.gap_mobile }}px;
    }
    .logo-bar-{{ section.id }} .logo-bar__item img,
    .logo-bar-{{ section.id }} .logo-bar__item svg {
      height: {{ section.settings.logo_height_mobile }}px;
    }
  }
{%- endstyle -%}

<div class="logo-bar-{{ section.id }}">
  <div class="logo-bar__row">
    {%- for block in section.blocks -%}
      <div class="logo-bar__item" {{ block.shopify_attributes }}>
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" style="display:flex;align-items:center;">
        {%- endif -%}
        {%- if block.settings.logo != blank -%}
          {{
            block.settings.logo
            | image_url: width: 400
            | image_tag: widths: '200, 300, 400', alt: block.settings.logo.alt, loading: 'lazy'
          }}
        {%- else -%}
          {{ 'logo' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        {%- if block.settings.link != blank -%}
          </a>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Barra de logos",
  "tag": "section",
  "class": "section-logo-bar",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#0a0a0a"
    },
    {
      "type": "checkbox",
      "id": "force_white",
      "label": "Forzar logos en blanco",
      "info": "Convierte cualquier logo a blanco automáticamente",
      "default": true
    },
    {
      "type": "range",
      "id": "logo_height_desktop",
      "label": "Altura logos PC (px)",
      "min": 16,
      "max": 80,
      "step": 2,
      "default": 38
    },
    {
      "type": "range",
      "id": "logo_height_mobile",
      "label": "Altura logos móvil (px)",
      "min": 12,
      "max": 50,
      "step": 2,
      "default": 20
    },
    {
      "type": "range",
      "id": "gap_desktop",
      "label": "Separación PC (px)",
      "min": 10,
      "max": 100,
      "step": 5,
      "default": 40
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "label": "Separación móvil (px)",
      "min": 8,
      "max": 60,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Espaciado superior (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 28
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Espaciado inferior (px)",
      "min": 0,
      "max": 100,
      "step": 4,
      "default": 28
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Imagen del logo",
          "info": "Preferible PNG o SVG con fondo transparente"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace (opcional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Barra de logos",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
